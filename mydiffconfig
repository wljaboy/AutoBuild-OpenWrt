# ===== 目标平台配置 =====
CONFIG_TARGET_x86=y
CONFIG_TARGET_x86_64=y
CONFIG_TARGET_x86_64_Generic=y

# ===== 引导与分区配置 =====
CONFIG_PACKAGE_grub2-efi=y
CONFIG_EFI_IMAGES=y
CONFIG_TARGET_IMAGES_GZIP=y
CONFIG_TARGET_KERNEL_PARTSIZE=64            # 增加内核分区大小
CONFIG_TARGET_ROOTFS_PARTSIZE=30000         # 30GB根分区
# CONFIG_GRUB_CONSOLE is not set

# ===== Docker核心组件 =====
CONFIG_PACKAGE_dockerd=y
CONFIG_PACKAGE_docker=y
CONFIG_PACKAGE_docker-compose=y
CONFIG_PACKAGE_libnetwork=y
CONFIG_PACKAGE_tini=y
CONFIG_PACKAGE_containerd=y
CONFIG_PACKAGE_runc=y

# ===== Docker图形化管理界面 =====
CONFIG_PACKAGE_luci-app-dockerman=y         # Docker管理界面
CONFIG_PACKAGE_luci-lib-docker=y            # 必须依赖
CONFIG_PACKAGE_luci-lib-jsonc=y             # JSON解析库
CONFIG_PACKAGE_luci-i18n-dockerman-zh-cn=y  # 中文语言包
CONFIG_PACKAGE_docker-bash-completion=y     # CLI自动补全
CONFIG_PACKAGE_docker-proxy=y               # 网络代理组件

# ===== Linux内核强制依赖 =====
CONFIG_KERNEL_CGROUPS=y
CONFIG_KERNEL_NAMESPACES=y
CONFIG_KERNEL_SECCOMP=y
CONFIG_KERNEL_SECCOMP_FILTER=y
CONFIG_KERNEL_CGROUP_DEVICE=y
CONFIG_KERNEL_CGROUP_FREEZER=y
CONFIG_KERNEL_CGROUP_NET_PRIO=y
CONFIG_KERNEL_CGROUP_PERF=y
CONFIG_KERNEL_EXT4_FS_POSIX_ACL=y
CONFIG_KERNEL_EXT4_FS_SECURITY=y
CONFIG_KERNEL_OVERLAY_FS=y
CONFIG_KERNEL_VETH=y
CONFIG_KERNEL_NET_CLS_CGROUP=y
CONFIG_KERNEL_CFS_BANDWIDTH=y               # CPU限制支持
CONFIG_KERNEL_MEMCG=y                       # 内存cgroup支持
CONFIG_KERNEL_MEMCG_SWAP=y
CONFIG_KERNEL_IPC_NS=y                      # IPC命名空间
CONFIG_KERNEL_UTS_NS=y                      # UTS命名空间
CONFIG_KERNEL_PID_NS=y                      # PID命名空间
CONFIG_KERNEL_NET_NS=y                      # 网络命名空间

# ===== 文件系统完整支持 =====
CONFIG_PACKAGE_kmod-fs-btrfs=y
CONFIG_PACKAGE_btrfs-progs=y                # Btrfs管理工具
CONFIG_PACKAGE_kmod-fuse=y
CONFIG_PACKAGE_kmod-dm=y
CONFIG_PACKAGE_kmod-ikconfig=y
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_e2fsprogs=y                  # ext2/3/4工具集
CONFIG_PACKAGE_kmod-fs-vfat=y               # FAT支持
CONFIG_PACKAGE_kmod-fs-nfs=y                # NFS客户端支持
CONFIG_PACKAGE_kmod-fs-nfs-common=y
CONFIG_PACKAGE_kmod-fs-nfs-v3=y
CONFIG_PACKAGE_kmod-fs-nfs-v4=y
CONFIG_PACKAGE_kmod-fs-overlay=y            # OverlayFS支持
CONFIG_PACKAGE_kmod-fs-xfs=y                # XFS支持

# ===== 存储库依赖 =====
CONFIG_PACKAGE_libblkid=y
CONFIG_PACKAGE_libmount=y
CONFIG_PACKAGE_librt=y
CONFIG_PACKAGE_libseccomp=y
CONFIG_PACKAGE_libdevmapper=y
CONFIG_PACKAGE_libcgroup=y
CONFIG_PACKAGE_libapparmor=y                # AppArmor支持
CONFIG_PACKAGE_libattr=y
CONFIG_PACKAGE_libcap=y
CONFIG_PACKAGE_libcap-bin=y
CONFIG_PACKAGE_libjson-c=y                  # JSON-C库
CONFIG_PACKAGE_liblucihttp=y                # LuCI HTTP库
CONFIG_PACKAGE_liblucihttp-lua=y
CONFIG_PACKAGE_libnetwork=y

# ===== 网络增强 =====
CONFIG_PACKAGE_kmod-ipt-ipset=y
CONFIG_PACKAGE_kmod-ipt-conntrack-extra=y
CONFIG_PACKAGE_kmod-ipt-nat6=y              # IPv6 NAT支持
CONFIG_PACKAGE_kmod-br-netfilter=y          # 网桥过滤
CONFIG_PACKAGE_kmod-vxlan=y                 # 虚拟网络支持
CONFIG_PACKAGE_ip-full=y
CONFIG_PACKAGE_kmod-ipt-tproxy=y            # 透明代理
CONFIG_PACKAGE_kmod-nf-nat=y                # NAT支持
CONFIG_PACKAGE_kmod-nf-nat6=y               # IPv6 NAT

# ===== 容器必备工具 =====
CONFIG_PACKAGE_cgroupfs-mount=y             # 自动挂载cgroup
CONFIG_PACKAGE_iptables-mod-extra=y         # 扩展iptables模块
CONFIG_PACKAGE_fdisk=y                      # 分区工具
CONFIG_PACKAGE_lsblk=y                      # 块设备查看工具
CONFIG_PACKAGE_usbutils=y                   # USB设备工具
CONFIG_PACKAGE_losetup=y                    # 循环设备管理
CONFIG_PACKAGE_mount-utils=y                # 挂载工具
CONFIG_PACKAGE_kmod-loop=y                  # 循环设备支持
CONFIG_PACKAGE_lscpu=y                      # CPU信息工具
CONFIG_PACKAGE_lsscsi=y                     # SCSI设备工具

# ===== LuCI基础框架 =====
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-compat=y
CONFIG_PACKAGE_luci-mod-admin-full=y
CONFIG_PACKAGE_luci-theme-bootstrap=y       # 基础主题
CONFIG_PACKAGE_luci-app-firewall=y          # 防火墙

# ===== 其他应用配置 =====
CONFIG_PACKAGE_luci-app-ssr-plus=y
CONFIG_PACKAGE_luci-app-ssr-plus_INCLUDE_Shadowsocks=y
CONFIG_PACKAGE_luci-app-ssr-plus_INCLUDE_Shadowsocks_Rust=y
CONFIG_PACKAGE_luci-app-ssr-plus_INCLUDE_V2ray_plugin=y
CONFIG_PACKAGE_luci-app-ssr-plus_INCLUDE_Xray=y
CONFIG_PACKAGE_luci-app-ssr-plus_INCLUDE_Trojan=y
CONFIG_PACKAGE_luci-app-ssr-plus_INCLUDE_Redsocks2=y
CONFIG_PACKAGE_luci-app-ssr-plus_INCLUDE_NaiveProxy=y
CONFIG_PACKAGE_luci-app-ssr-plus_INCLUDE_Kcptun=y
CONFIG_PACKAGE_luci-app-ssr-plus_INCLUDE_ShadowsocksR_Server=y
CONFIG_PACKAGE_luci-i18n-ssr-plus-zh-cn=y
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-app-mwan3=y
CONFIG_PACKAGE_luci-app-mwan3helper=y
CONFIG_PACKAGE_luci-i18n-mwan3-zh-cn=y
CONFIG_PACKAGE_luci-i18n-mwan3helper-zh-cn=y
CONFIG_PACKAGE_luci-app-syncdial=y
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_luci-i18n-ttyd-zh-cn=y
CONFIG_PACKAGE_luci-app-webadmin=y
CONFIG_PACKAGE_luci-i18n-webadmin-zh-cn=y

# ===== 系统优化 =====
CONFIG_PACKAGE_perl=y                       # Docker Compose依赖
CONFIG_PACKAGE_perl-http-date=y
CONFIG_PACKAGE_perlbase-base=y
CONFIG_PACKAGE_perlbase-essential=y
CONFIG_PACKAGE_python3=y                    # 部分Docker工具依赖
CONFIG_PACKAGE_python3-pip=y
CONFIG_PACKAGE_python3-dev=y
CONFIG_PACKAGE_python3-setuptools=y
CONFIG_PACKAGE_bash=y                       # 更好的Shell支持
